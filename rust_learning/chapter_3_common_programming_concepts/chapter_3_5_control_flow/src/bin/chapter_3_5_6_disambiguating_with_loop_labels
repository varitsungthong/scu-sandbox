fn main() {
    let mut count = 0;
    'counting_up: loop {
        println!("count = {count}");
        let mut remaining = 10;

        loop {
            println!("remaining = {remaining}");
            if remaining == 9 {
                break; //line 10 break the inner loop within 'counting_up' loop returning to the line 4 when remaining is equal to 9 and when it goes back to line 5 the 'remaining' variables get reset to 10
            }
            if count == 2 {
                break 'counting_up;
            }
            remaining -= 1;
        }

        count += 1;
    }
    println!("End count = {count}");
}