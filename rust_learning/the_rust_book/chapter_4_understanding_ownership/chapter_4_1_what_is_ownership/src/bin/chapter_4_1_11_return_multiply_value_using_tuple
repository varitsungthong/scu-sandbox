fn main (){
    let s1 = String::from("hello"); //statement
    let (s2, len) = calculate_length(s1); //statement 
                                          // this line make s1 invalid because ownership moved into the function


    println!("The length of '{s2}' is {len}."); //tell the progam to print

}
fn calculate_length(s: String) -> (String, usize) { 
    //fn calculate_length(s:String) : declare function name calculate_length with entry input data be call 's' as String. 
    //-> (String, usize) : the function expert the return value to be Tuple Type with (String , Unsigned Size)
     
                                                    
    let length = s.len(); //use len to count number of characters of 's' variable and return the value in bytes to variable 'length'

    (s, length) //return Tuple , is expression
}