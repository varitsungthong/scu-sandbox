use std::fs::File;
use std::io::ErrorKind;

fn main() {
    //unwrap_or_else method is more concise than match 
    //unwrap_or_else unwrap the results form File::open and if cant unwrap this will produce error
    let greeting_file = File::open("hello.txt").unwrap_or_else(|error| {
        //asses the error from unwrap_or_else using error.kind
        //if error.kind is NotFOund this will create a new file
        //else will call panic! macro
        if error.kind() == ErrorKind::NotFound {
            File::create("hello.txt").unwrap_or_else(|error| {
                panic!("Problem creating the file: {error:?}");
            })
        } else {
            panic!("Problem opening the file: {error:?}");
        }
    });
}