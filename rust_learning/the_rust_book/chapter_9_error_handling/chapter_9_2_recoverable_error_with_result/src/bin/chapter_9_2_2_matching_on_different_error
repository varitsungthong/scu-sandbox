use std::fs::File;
use std::io::ErrorKind;

fn main() {
    //open file return Result<T,E>
    let greeting_file_result = File::open("hello.txt");

    //use match to handle result variant that return form open file
    let greeting_file = match greeting_file_result {
        //if return ok this will return file inside ok value
        Ok(file) => file,
        // use match expression with error to handle different kind of error
        //This inner match check whether the value return by error.kind is 
        //the NotFound variant of the ErrorKind enum if it is 
        //we try to create the file with File::create

        Err(error) => match error.kind() {
            //ErrorKind::NotFound indicates that the file we want to open doesn't exist yet
            ErrorKind::NotFound => match File::create("hello.txt") {
                Ok(fc) => fc,
                //if file cant be create this arm will trigger panic! macro
                Err(e) => panic!("Problem creating the file: {e:?}"), 
            },
            _ => {
                panic!("Problem opening the file: {error:?}");
            }
        },
    };
}