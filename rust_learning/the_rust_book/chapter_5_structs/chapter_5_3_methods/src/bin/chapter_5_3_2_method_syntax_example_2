#[derive(Debug)]
struct Rectangle {
    width : u32,
    height : u32,
}
impl Rectangle{
    fn width(&self) -> bool { //method fn can be the same name as one of sturct field
        self.width > 0
}
}
fn main() {
    let rect1 = Rectangle {
        width : 69,
        height : 67,

    };

    if rect1.width() {
        println!("The rectangle has a nonzero width; it is {}", rect1.width);
    }
}

